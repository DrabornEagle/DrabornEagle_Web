# DraBornDeal / Firsat Radari CX33 worker env example
# Copy this file to .env on Hetzner CX33 and fill real values there.

DKD_SUPABASE_URL=https://guuwomvszlwhkmstewfl.supabase.co
DKD_SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

DKD_WORKER_KEY=dkd-cx33-main-01
DKD_WORKER_COUNTRY=TR
DKD_WORKER_DRY_RUN=true
DKD_WORKER_LOOP=false
DKD_WORKER_POLL_SECONDS=30
DKD_WORKER_JOB_LIMIT=5

DKD_ENABLE_SOURCE_DISCOVERY=false
DKD_ENABLE_WATCH_LINKS=true
DKD_ENABLE_TELEGRAM=false

DKD_TELEGRAM_BOT_TOKEN=replace_later
DKD_TELEGRAM_CHAT_ID_TR_MAIN=replace_later
DKD_TELEGRAM_CHAT_ID_TR_HOT=replace_later
