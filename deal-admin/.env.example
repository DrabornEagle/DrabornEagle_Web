# DraBornDeal Admin Panel env example
# Copy to .env in Termux or CX33. Never commit real .env.

DKD_ADMIN_PORT=8787
DKD_ADMIN_PANEL_KEY=local-admin-key-change-me

DKD_SUPABASE_URL=https://guuwomvszlwhkmstewfl.supabase.co
DKD_SUPABASE_SERVICE_ROLE_KEY=PASTE_VALUE_IN_LOCAL_ENV_ONLY

# Direct Telegram sharing from admin panel and crawler worker.
# Copy this from deal-worker/.env.
DKD_TELEGRAM_BOT_TOKEN=PASTE_VALUE_IN_LOCAL_ENV_ONLY

# Old page crawler settings.
DKD_AUTO_CRAWL_INTERVAL_MINUTES=30
DKD_AUTO_CRAWL_SHARE_LIMIT=5
DKD_CRAWL_SEED_URLS=https://www.trendyol.com/sr?q=telefon,https://www.trendyol.com/sr?q=playstation,https://www.hepsiburada.com/ara?q=telefon,https://www.hepsiburada.com/ara?q=playstation

# DraBornBee gateway settings.
# This is the ScrapingBee-like local fetch gateway layer.
DKD_GATEWAY_INTERVAL_MINUTES=45
DKD_GATEWAY_SHARE_LIMIT=5
DKD_GATEWAY_SOURCE_HOMES=https://www.trendyol.com,https://www.hepsiburada.com
DKD_GATEWAY_SITEMAP_LIMIT=10
DKD_GATEWAY_PRODUCT_LIMIT=80
DKD_GATEWAY_TIMEOUT_MS=16000
DKD_GATEWAY_RETRIES=2
