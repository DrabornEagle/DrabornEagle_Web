# DraBornDeal Admin Panel env example
# Copy to .env in Termux or CX33. Never commit real .env.

DKD_ADMIN_PORT=8787
DKD_WORKER_CONTROL_PORT=8788
DKD_CLICK_PORT=8789
DKD_ADMIN_PANEL_KEY=local-admin-key-change-me

DKD_SUPABASE_URL=https://guuwomvszlwhkmstewfl.supabase.co
DKD_SUPABASE_SERVICE_ROLE_KEY=PASTE_VALUE_IN_LOCAL_ENV_ONLY
DKD_TELEGRAM_BOT_TOKEN=PASTE_VALUE_IN_LOCAL_ENV_ONLY

DKD_CLICK_TRACKING_ENABLED=false
DKD_PUBLIC_BASE_URL=https://www.draborneagle.com
DKD_CLICK_HASH_SALT=change-this-random-secret

# DraBornBee worker settings.
DKD_GATEWAY_INTERVAL_MINUTES=45
DKD_GATEWAY_SHARE_LIMIT=5
DKD_WORKER_ATTEMPT_LIMIT=25
DKD_MIN_DISCOUNT_PERCENT=5

# DraBornBee service connection. Leave empty until the server is ready.
DKD_DRABORNBEE_URL=
DKD_DRABORNBEE_KEY=

# Hepsiburada and campaign discovery limits.
DKD_CAMPAIGN_TIMEOUT_MS=14000
DKD_CAMPAIGN_URL_LIMIT=80
DKD_HEPSI_DEAL_TIMEOUT_MS=15000
DKD_HEPSI_DEAL_URL_LIMIT=80

DKD_ADAPTER_SITEMAP_LIMIT=8
DKD_ADAPTER_PRODUCT_LIMIT=40
DKD_ADAPTER_TIMEOUT_MS=18000
